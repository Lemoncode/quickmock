{
  "name": "@lemoncode/quickmock-mcp",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "imports": {
    "#*": "./src/*"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "inspect": "npm run build && npx @modelcontextprotocol/inspector node dist/index.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "puppeteer": "^24.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@lemoncode/typescript-config": "*",
    "@lemoncode/tsdown-config": "*",
    "@lemoncode/vitest-config": "*",
    "@types/node": "22.x"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Lemoncode/quickmock",
    "directory": "packages/mcp"
  }
}
