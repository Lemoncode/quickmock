{
  "name": "@lemoncode/web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "imports": {
    "#*": "./src/*"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "check-types": "tsc --noEmit",
    "check-types:watch": "node --run check-types -- --watch --preserveWatchOutput",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test --ui",
    "ci:e2e": "playwright test"
  },
  "dependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "1.7.10",
    "@fontsource-variable/montserrat": "5.2.8",
    "@fontsource/balsamiq-sans": "5.2.8",
    "@uiw/react-color-chrome": "2.10.1",
    "html2canvas": "1.4.1",
    "immer": "11.1.4",
    "konva": "10.2.5",
    "lodash.clonedeep": "4.5.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-konva": "19.2.3",
    "react-konva-utils": "2.0.0",
    "tiny-invariant": "1.3.3",
    "use-debounce": "10.1.1",
    "use-image": "1.1.4",
    "uuid": "13.0.0"
  },
  "devDependencies": {
    "@lemoncode/typescript-config": "*",
    "@lemoncode/vitest-config": "*",
    "@playwright/test": "1.59.1",
    "@types/lodash.clonedeep": "4.5.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/uuid": "10.0.0",
    "@types/wicg-file-system-access": "2023.10.5",
    "@vitejs/plugin-react": "6.0.1",
    "vite": "8.0.8"
  }
}
